{
	"info": {
		"_postman_id": "4b62d8a5-7b5e-4e2a-b9d1-8f5c6d3f4e2a",
		"name": "QR Order API (Organisée par Rôle)",
		"description": "Collection pour tester l'API de commande par QR Code, organisée par rôle utilisateur.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "0. SCÉNARIO : Scan QR & Commande (Client)",
			"description": "Ce dossier simule le parcours complet d'un client qui scanne un QR Code, consulte le menu et passe commande.",
			"item": [
				{
					"name": "1. [Scan QR] Charger le Restaurant et son Menu",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/restaurants/:id",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"restaurants",
								":id"
							],
							"variable": [
								{
									"key": "id",
									"value": "uuid-du-restaurant"
								}
							]
						},
						"description": "Cette requête simule ce qui se passe quand le client scanne le QR Code. Le frontend récupère toutes les infos du restaurant, ses catégories et ses plats."
					},
					"response": []
				},
				{
					"name": "2. [Action] Envoyer la Commande",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"restaurantId\": \"uuid-du-restaurant\",\n    \"tableId\": \"uuid-de-la-table-venue-du-qr\",\n    \"items\": [\n        {\n            \"menuItemId\": \"uuid-du-plat\",\n            \"quantity\": 2,\n            \"note\": \"Sans sel\"\n        }\n    ],\n    \"note\": \"Commande urgente\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/orders",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"orders"
							]
						},
						"description": "Le client valide son panier. L'ID de la table est extrait du QR Code scanné au début."
					},
					"response": []
				},
				{
					"name": "3. [Suivi] Consulter l'état de ma commande",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/orders/:id",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"orders",
								":id"
							],
							"variable": [
								{
									"key": "id",
									"value": "uuid-de-la-commande-creee"
								}
							]
						},
						"description": "Le client peut voir si sa commande est en préparation ou servie."
					},
					"response": []
				}
			]
		},
